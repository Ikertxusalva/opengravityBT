{
  "name": "opengravity-app",
  "version": "0.1.0",
  "private": true,
  "description": "OpenGravity Multi-Agent Terminal Dashboard",
  "main": "app/index.js",
  "scripts": {
    "dev": "tsc -p main/tsconfig.json && nextron --run-only",
    "dev:watch": "concurrently \"tsc -p main/tsconfig.json -w\" \"nextron --run-only\"",
    "build": "tsc -p main/tsconfig.json && nextron build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-serve": "^1.3.0",
    "electron-store": "^10.0.0",
    "keytar": "^7.9.0",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/keytar": "^4.4.0",
    "@types/node": "^20.11.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "next": "^14.2.0",
    "nextron": "^9.0.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
